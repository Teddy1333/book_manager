# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection used by the API service.
# Default matches the docker-compose postgres service credentials.
POSTGRES_USER=bookuser
POSTGRES_PASSWORD=bookpass
POSTGRES_DB=bookdb
# DATABASE_URL=postgresql://bookuser:bookpass@postgres:5432/bookdb

# ── Auth / Security ───────────────────────────────────────────────────────────
# Secret key for signing JWT tokens. Change this before deploying to production.
BOOK_MANAGER_SECRET_KEY=diplomna_rabota_pu_key

# ── Internal service URLs (used inside docker-compose network) ─────────────────
# These work as-is when running with docker-compose.
# Override only if you move services to different hosts/ports.
# AI_SERVICE_URL=http://ai:8001
# SCRAPER_SERVICE_URL=http://scraper:8002
# API_BASE_URL=http://api:8000

# ── Exposed ports (host machine) ──────────────────────────────────────────────
# Ports mapped from containers to your local machine.
# POSTGRES_PORT=5432
# API_PORT=8000
# AI_PORT=8001
# SCRAPER_PORT=8002
# FRONTEND_PORT=3000

# ── OpenAI-compatible Vision API ───────────────────────────────────────────────
# Works with Gemini, OpenAI, or any OpenAI-compatible provider.
# For Gemini: get your key at https://aistudio.google.com/apikey
OPENAI_API_KEY=the_key
# For Gemini use: https://generativelanguage.googleapis.com/v1beta/openai/
# For OpenAI use: https://api.openai.com/v1
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Model name (Gemini: gemini-2.5-flash, gemini-2.5-pro; OpenAI: gpt-4o, gpt-4o-mini)
OPENAI_VISION_MODEL=gemini-2.5-flash

